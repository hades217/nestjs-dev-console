{
  "name": "@airbotix/nestjs-dev-console",
  "version": "0.3.0",
  "description": "Local-dev-only impersonation console for NestJS: a role/entity map with one-click \"Login as\" that mints a REAL session and deep-links into your frontends. Default-deny gated — never reachable in production.",
  "keywords": [
    "nestjs",
    "dev-tools",
    "impersonation",
    "login-as",
    "persona-switcher",
    "account-switcher",
    "local-dev",
    "fixtures",
    "developer-experience"
  ],
  "license": "MIT",
  "author": "Airbotix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hades217/nestjs-dev-console.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "node -e \"require('fs').copyFileSync('src/dev-console.html','dist/dev-console.html')\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "express": "^4.19.2",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  }
}
